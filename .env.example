# Environment Configuration for Resume Agent

# OpenAI API Configuration
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://llm.gauravshivaprasad.com/v1
OPENAI_MODEL=o3

# LLM Settings
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=2000
LLM_TIMEOUT=60

# Application Settings
LOG_LEVEL=INFO

# Optional: Web Search API Keys
TAVILY_API_KEY=

# Note: Copy this file to .env and fill in your actual values
# The .env file should NOT be committed to version control
