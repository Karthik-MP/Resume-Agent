# Environment Configuration for Resume Agent

# ===== LLM Provider Configuration =====
# Options: openai (ChatGPT), custom (your deployed model), gemini (future)
LLM_PROVIDER=openai

# ===== OpenAI Configuration (ChatGPT) =====
# For using ChatGPT models (gpt-4o-mini, gpt-4o, etc.)
OPENAI_API_KEY=sk-proj-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ===== Custom Model Configuration =====
# For your deployed models
CUSTOM_API_KEY=your-custom-api-key
CUSTOM_BASE_URL=https://llm.gauravshivaprasad.com/v1
CUSTOM_MODEL=o3

# ===== Gemini Configuration (Future Support) =====
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-pro

# ===== LLM Settings =====
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2000
LLM_TIMEOUT=60

# ===== Application Settings =====
LOG_LEVEL=INFO

# ===== Optional: Web Search API Keys =====
TAVILY_API_KEY=

# Note: Copy this file to .env and fill in your actual values
# The .env file should NOT be committed to version control
